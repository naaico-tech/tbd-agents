# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=copilot_agent_hub

# Copilot SDK
DEFAULT_MODEL=gpt-4.1
DEFAULT_MAX_TURNS=5
SESSION_TIMEOUT=300
# Optional server-level GitHub token (per-request Bearer tokens take priority)
# Requires `copilot` scope — https://github.com/settings/tokens
GITHUB_TOKEN=

# Datadog MCP — https://docs.datadoghq.com/account_management/api-app-keys/
DD_API_KEY=your_datadog_api_key
DD_APP_KEY=your_datadog_app_key
DD_SITE=datadoghq.com

# Atlassian / Jira MCP — https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_API_TOKEN=your_atlassian_api_token
ATLASSIAN_EMAIL=you@company.com
ATLASSIAN_URL=https://yourcompany.atlassian.net
