# =============================================================================
# DEPLOYMENT PROFILE & DATABASE BACKEND
# =============================================================================
# Choose ONE profile that controls BOTH the vector store AND the document store.
#
#  ┌─────────────────┬────────────────────────────┬────────────────────────┐
#  │ COMPOSE_PROFILES│ Document store             │ Vector store           │
#  ├─────────────────┼────────────────────────────┼────────────────────────┤
#  │ qdrant          │ MongoDB 7                  │ Qdrant                 │
#  │ pgvector        │ PostgreSQL 17 (JSONB)       │ pgvector extension     │
#  └─────────────────┴────────────────────────────┴────────────────────────┘
#
# The pgvector profile uses a SINGLE PostgreSQL instance for everything —
# no MongoDB required.  Run `alembic upgrade head` after first startup.
#
# See docs/guide/postgres-backend.md for the full PostgreSQL setup guide.
# =============================================================================

# ── Profile selection ─────────────────────────────────────────────────────
# Uncomment exactly ONE of the two blocks below:

# Block A — Qdrant profile (MongoDB + Qdrant)
# COMPOSE_PROFILES=qdrant
# DB_BACKEND=mongo
# VECTOR_STORE_BACKEND=qdrant

# Block B — pgvector profile (PostgreSQL only — recommended for new deployments)
# COMPOSE_PROFILES=pgvector
# DB_BACKEND=postgres          # ← must be set to "postgres" with pgvector profile
# VECTOR_STORE_BACKEND=pgvector

# Active default (change to Block B values to switch to pgvector):
COMPOSE_PROFILES=qdrant
DB_BACKEND=mongo               # "mongo" or "postgres" — must match COMPOSE_PROFILES

# MongoDB (used with COMPOSE_PROFILES=qdrant / DB_BACKEND=mongo)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=copilot_agent_hub

# PostgreSQL (used with COMPOSE_PROFILES=pgvector / DB_BACKEND=postgres)
# Also acts as the pgvector backend when VECTOR_STORE_BACKEND=pgvector.
# Inside Docker Compose use host "postgres"; outside Docker use "localhost".
POSTGRES_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/tbd_agents

# Redis (Celery broker/backend + event bus pub/sub)
REDIS_URL=redis://redis:6379/0

# Copilot SDK
DEFAULT_MODEL=gpt-4.1
DEFAULT_MAX_TURNS=5
SESSION_TIMEOUT=600
# Optional server-level GitHub token (per-request Bearer tokens take priority)
# Requires `copilot` scope — https://github.com/settings/tokens
GITHUB_TOKEN=

# Token encryption key for the built-in secret store
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# OpenTelemetry (optional — used by the observability stack)
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_HTTP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=tbd-agents

# ── Vector Store ─────────────────────────────────────────────────────────────
# COMPOSE_PROFILES and VECTOR_STORE_BACKEND are set in the profile block above.
# When running the app OUTSIDE Docker (e.g. uvicorn locally), start only the
# relevant DB container:
#   docker compose --profile qdrant up qdrant
#   docker compose --profile pgvector up postgres

# Qdrant (used when VECTOR_STORE_BACKEND=qdrant)
# Use http://qdrant:6333 inside Docker Compose, http://localhost:6333 outside.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# PgVector settings (used when VECTOR_STORE_BACKEND=pgvector)
# DSN defaults to POSTGRES_URI above; override here only if different.
# PGVECTOR_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/tbd_agents
# PGVECTOR_TABLE_PREFIX=vs
