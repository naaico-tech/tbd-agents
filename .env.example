# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=copilot_agent_hub

# Redis (Celery broker/backend + event bus pub/sub)
REDIS_URL=redis://redis:6379/0

# Copilot SDK
DEFAULT_MODEL=gpt-4.1
DEFAULT_MAX_TURNS=5
SESSION_TIMEOUT=600
# Optional server-level GitHub token (per-request Bearer tokens take priority)
# Requires `copilot` scope — https://github.com/settings/tokens
GITHUB_TOKEN=

# Token encryption key for the built-in secret store
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# OpenTelemetry (optional — used by the observability stack)
OTEL_ENDPOINT=http://otel-collector:4317
OTEL_HTTP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=tbd-agents
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-key-here

# Feature flags
# Set to false to disable third-party base_url support for the anthropic provider type.
# When enabled, anthropic providers with a base_url route the Claude Agent SDK through
# that URL (e.g. a LiteLLM proxy) instead of the default Anthropic endpoint.
CLAUDE_SDK_THIRD_PARTY_PROVIDERS_ENABLED=true 
