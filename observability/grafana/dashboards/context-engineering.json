{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Overview",
      "url": "/d/overview",
      "type": "link",
      "icon": "external link",
      "includeVars": true,
      "keepTime": true
    },
    {
      "title": "LLM Analytics",
      "url": "/d/llm-analytics",
      "type": "link",
      "icon": "external link",
      "includeVars": true,
      "keepTime": true
    }
  ],
  "panels": [

    {
      "id": 1,
      "title": "Context Usage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },

    {
      "id": 2,
      "title": "Compaction Events / min",
      "description": "Rate of context compaction triggers. Spikes indicate sessions approaching their context window limit.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short",
          "displayName": "${__series.name}"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (model) (rate(copilot_hub_context_compactions_total[5m])) * 60",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "Messages Dropped per Compaction (p50 / p95)",
      "description": "How aggressively compaction is trimming context. High p95 means sessions are running very long.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(copilot_hub_context_compaction_messages_dropped_bucket[10m])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(copilot_hub_context_compaction_messages_dropped_bucket[10m])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 4,
      "title": "Total Compactions (counter)",
      "description": "Cumulative compaction count since last restart.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(copilot_hub_context_compactions_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Avg Messages Dropped / Compaction",
      "description": "Average trimming depth across all models.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "short",
          "decimals": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_context_compaction_messages_dropped_sum[10m])) / sum(rate(copilot_hub_context_compaction_messages_dropped_count[10m]))",
          "legendFormat": "Avg dropped",
          "refId": "A"
        }
      ]
    },

    {
      "id": 10,
      "title": "Semantic Retrieval",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },

    {
      "id": 11,
      "title": "Semantic Retrieval Hits / min",
      "description": "Rate of successful semantic retrievals (Qdrant returned results). Separated by memory vs knowledge.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (type) (rate(copilot_hub_semantic_retrieval_hits_total[5m])) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "title": "Retrieval Results per Call (p50 / p95)",
      "description": "How many chunks/memories are returned per retrieval. Low p50 may indicate Qdrant is empty or misconfigured.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (type, le) (rate(copilot_hub_semantic_retrieval_results_bucket[10m])))",
          "legendFormat": "p50 {{type}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (type, le) (rate(copilot_hub_semantic_retrieval_results_bucket[10m])))",
          "legendFormat": "p95 {{type}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 13,
      "title": "Retrieval Hit Rate",
      "description": "Fraction of retrieval calls that returned at least one result (memory + knowledge combined).",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.4 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_semantic_retrieval_hits_total[10m])) / (sum(rate(copilot_hub_semantic_retrieval_results_count[10m])) > 0)",
          "legendFormat": "Hit rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 14,
      "title": "Total Semantic Hits",
      "description": "Cumulative semantic retrieval hits (memory + knowledge) since last restart.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(copilot_hub_semantic_retrieval_hits_total)",
          "legendFormat": "Total hits",
          "refId": "A"
        }
      ]
    },

    {
      "id": 20,
      "title": "Embeddings",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "id": 21,
      "title": "Embedding Requests / min by Status",
      "description": "Success = model ran; failure = exception; disabled = embeddings_enabled=false or model not loaded.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "disabled" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (status) (rate(copilot_hub_embeddings_requests_total[5m])) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 22,
      "title": "Embedding Error Rate",
      "description": "Fraction of embedding calls that failed (exceptions). >5% warrants investigation.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_embeddings_requests_total{status=\"failure\"}[10m])) / (sum(rate(copilot_hub_embeddings_requests_total[10m])) > 0)",
          "legendFormat": "Error rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 23,
      "title": "Embedding Availability",
      "description": "green = embeddings active, red = all calls disabled/failing.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "clamp_max(sum(rate(copilot_hub_embeddings_requests_total{status=\"success\"}[5m])) > bool 0, 1)",
          "legendFormat": "Status",
          "refId": "A"
        }
      ]
    },

    {
      "id": 30,
      "title": "Agent Task Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": false
    },

    {
      "id": 31,
      "title": "Active Tasks",
      "description": "Currently running agent tasks across all workers.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(copilot_hub_agent_tasks_active)",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },

    {
      "id": 32,
      "title": "Task Success Rate (5m)",
      "description": "Fraction of tasks completing successfully in the last 5 minutes.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_agent_tasks_total{status=\"success\"}[5m])) / (sum(rate(copilot_hub_agent_tasks_total[5m])) > 0)",
          "legendFormat": "Success rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 33,
      "title": "Compaction Rate vs Task Rate",
      "description": "Ratio of compaction events to task completions. High ratio = tasks regularly exhaust their context window.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "decimals": 2
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_context_compactions_total[10m])) / (sum(rate(copilot_hub_agent_tasks_total[10m])) > 0)",
          "legendFormat": "Compactions / task",
          "refId": "A"
        }
      ]
    },

    {
      "id": 34,
      "title": "Memory Semantic Hit Rate",
      "description": "Fraction of memory retrievals that used semantic (Qdrant) vs zero results returned.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_semantic_retrieval_hits_total{type=\"memory\"}[10m])) / (sum(rate(copilot_hub_semantic_retrieval_results_count{type=\"memory\"}[10m])) > 0)",
          "legendFormat": "Memory hit rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 35,
      "title": "Knowledge Semantic Hit Rate",
      "description": "Fraction of KB retrievals that used semantic (Qdrant) vs scroll fallback.",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_semantic_retrieval_hits_total{type=\"knowledge\"}[10m])) / (sum(rate(copilot_hub_semantic_retrieval_results_count{type=\"knowledge\"}[10m])) > 0)",
          "legendFormat": "Knowledge hit rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 36,
      "title": "Avg Embeddings Req / Task",
      "description": "How many embedding calls are made per task on average (memory + knowledge combined).",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "decimals": 1
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [
        {
          "expr": "sum(rate(copilot_hub_embeddings_requests_total{status=\"success\"}[10m])) / (sum(rate(copilot_hub_agent_tasks_total[10m])) > 0)",
          "legendFormat": "Embeds / task",
          "refId": "A"
        }
      ]
    },

    {
      "id": 40,
      "title": "Task Duration",
      "description": "End-to-end agent task execution time by model.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(copilot_hub_agent_task_duration_seconds_bucket[10m])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(copilot_hub_agent_task_duration_seconds_bucket[10m])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 41,
      "title": "Tool Calls per Task",
      "description": "Distribution of tool invocations per completed agent task.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(copilot_hub_tool_calls_per_task_bucket[10m])))",
          "legendFormat": "p50 {{model}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(copilot_hub_tool_calls_per_task_bucket[10m])))",
          "legendFormat": "p95 {{model}}",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["context-engineering", "agents", "llm"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Agent Context Engineering",
  "uid": "context-engineering",
  "version": 1
}
