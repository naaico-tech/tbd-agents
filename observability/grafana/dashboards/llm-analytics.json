{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "LLM Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Total Tokens (24h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_hub_tokens_total[24h]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Cost (24h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_hub_cost_dollars_total[24h]))",
          "legendFormat": "Cost",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Premium Requests (24h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "purple", "mode": "fixed" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(copilot_hub_premium_requests_total[24h]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Task Success Rate (24h)",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100,
          "min": 0,
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(increase(copilot_hub_agent_tasks_total{status=\"completed\"}[24h])) / sum(increase(copilot_hub_agent_tasks_total[24h]))",
          "legendFormat": "Success%",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Avg Task Duration (1h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "rate(copilot_hub_agent_task_duration_seconds_sum[1h]) / rate(copilot_hub_agent_task_duration_seconds_count[1h])",
          "legendFormat": "Avg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Avg Tool Calls per Task (1h)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(copilot_hub_tool_calls_per_task_sum[1h]) / rate(copilot_hub_tool_calls_per_task_count[1h])",
          "legendFormat": "Avg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Token Usage by Model",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Input vs Output Tokens Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "increase(copilot_hub_tokens_total{direction=\"input\"}[5m])",
          "legendFormat": "Input ({{model}})",
          "refId": "A"
        },
        {
          "expr": "increase(copilot_hub_tokens_total{direction=\"output\"}[5m])",
          "legendFormat": "Output ({{model}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 15, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "increase(copilot_hub_tokens_total{direction=\"cache_read\"}[5m])",
          "legendFormat": "Cache Read ({{model}})",
          "refId": "A"
        },
        {
          "expr": "increase(copilot_hub_tokens_total{direction=\"cache_write\"}[5m])",
          "legendFormat": "Cache Write ({{model}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "title": "Cost Analysis",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Cost Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": { "fillOpacity": 25, "lineWidth": 2, "drawStyle": "bars", "barAlignment": 0 },
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "expr": "increase(copilot_hub_cost_dollars_total[1h])",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "title": "Cost per Task",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(copilot_hub_cost_per_task_dollars_bucket[1h]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(copilot_hub_cost_per_task_dollars_bucket[1h]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 30,
      "title": "Agent & Model Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Task Duration by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(copilot_hub_agent_task_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 ({{model}})",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(copilot_hub_agent_task_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 ({{model}})",
          "refId": "B"
        }
      ]
    },
    {
      "id": 32,
      "title": "Tasks by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "increase(copilot_hub_agent_tasks_total[24h])",
          "legendFormat": "{{status}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 33,
      "title": "Tasks by Reasoning Effort",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "increase(copilot_hub_agent_tasks_total[24h]) > 0",
          "legendFormat": "{{reasoning_effort}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 40,
      "title": "Distributed Traces (Copilot SDK)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Recent Traces",
      "description": "Traces from the Copilot SDK — click to open in Tempo",
      "type": "traces",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "nativeSearch",
          "serviceName": "tbd-agents-api|tbd-agents-worker",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "title": "Application Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "collapsed": false
    },
    {
      "id": 51,
      "title": "Logs (App + Worker)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 45 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\"app|worker\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["copilot", "llm", "usage"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(copilot_hub_agent_tasks_total, model)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "model",
        "query": { "query": "label_values(copilot_hub_agent_tasks_total, model)", "refId": "model" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Copilot Agent Hub — LLM & Cost Analytics",
  "uid": "copilot-hub-llm",
  "version": 2
}
