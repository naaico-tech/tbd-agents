{
  "name": "aws",
  "transport_type": "stdio",
  "connection_config": {
    "command": "npx",
    "args": ["-y", "@aws/mcp-server"],
    "env": {
      "AWS_ACCESS_KEY_ID": "{{token:aws-access-key-id}}",
      "AWS_SECRET_ACCESS_KEY": "{{token:aws-secret-access-key}}",
      "AWS_REGION": "us-east-1"
    }
  },
  "tags": ["aws", "cloud", "infrastructure", "sre"]
}
